# =============================================================================
# Claude Code Configuration
# =============================================================================
# This file contains all Claude Code CLI configurable items.
# Copy this to config/claude.env and fill in your values.
# These will be loaded into .env and used to generate .claude/settings.json.

# -- Engine Selection ---------------------------------------------------------
# Set ENGINE_TYPE in .env (not here). "claude" (default) or "codex".
# When using "codex", also create config/config.toml (see config.toml.example)
# and set OPENAI_API_KEY in .env.

# -- Authentication -----------------------------------------------------------

# Anthropic API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Auth token (alternative to API key, e.g. for OAuth flows)
# ANTHROPIC_AUTH_TOKEN=

# -- API Endpoint -------------------------------------------------------------

# Custom API base URL (for proxies or compatible endpoints)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# -- Model Selection ----------------------------------------------------------

# Default model for Claude CLI
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Fine-grained model overrides
# ANTHROPIC_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_REASONING_MODEL=

# -- Behavior Control ---------------------------------------------------------

# Auto-compact context threshold (percentage, 0-100)
# CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=85

# Disable non-essential traffic (telemetry, etc). Set to 1 to disable.
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Bash command default timeout in milliseconds
# BASH_DEFAULT_TIMEOUT_MS=120000

# -- Network / Proxy ----------------------------------------------------------

# Standard HTTP proxy (applies to all outbound HTTP requests)
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=

# -- settings.json Overrides -------------------------------------------------
# The following CLAUDE_SETTINGS_* variables are mapped into .claude/settings.json
# at container startup. They control the Claude CLI project-level behavior.

# UI language (e.g. "中文", "en")
# CLAUDE_SETTINGS_LANGUAGE=

# Include "Co-Authored-By" in git commits (true/false)
# CLAUDE_SETTINGS_INCLUDE_COAUTHORED_BY=

# Allowed tool patterns (comma-separated, e.g. "Bash(git *),Read,Write")
# CLAUDE_SETTINGS_PERMISSIONS_ALLOW=

# MCP servers are configured via .claude/settings.json template and
# populated from env vars (FEISHU_APP_ID, FEISHU_APP_SECRET, etc.)

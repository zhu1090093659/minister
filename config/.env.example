# Feishu App credentials (from open.feishu.cn)
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
ADMIN_BASE_URL=http://localhost:3000 # 管理面板的域名

# Engine selection: "claude" (default) or "codex"
# ENGINE_TYPE=claude

# Required when ENGINE_TYPE=codex (also configure config/config.toml)
# OPENAI_API_KEY=your_openai_api_key

# Claude Code configuration is in config/claude.env
# See config/claude.env.example for all available options.
